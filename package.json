{
  "name": "@vita-site/plugin-search",
  "version": "1.0.0-alpha.1",
  "description": "search plugin for VitaSite",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhuchonglin/vita-site-plugin-search"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm test && rimraf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "release": "npx change-push"
  },
  "license": "MIT",
  "peerDependencies": {
    "vita-site": "^1.0.0-0"
  },
  "devDependencies": {
    "vita-site": "^1.0.2",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.4",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vitarx-router": "^4.0.3"
  }
}
